kubeProxyReplacement: true
ipam:
  mode: kubernetes
k8sServiceHost: {{ kubernetes_api_ip }}
k8sServicePort: 6443
l2announcements:
  enabled: true
k8sClientRateLimit:
  qps: 20
  burst: 40
operator:
  replicas: {{ 2 if groups['kube_control_plane'] | length > 1 else 1 }}
hubble:
  relay:
    enabled: true
  ui:
    enabled: true
